# Choose provider: openrouter or openai (optional; auto-select if omitted)
LLM_PROVIDER=openrouter

# OpenRouter (recommended for cheap/open models)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=moonshotai/kimi-k2.5
# Optional metadata headers for OpenRouter analytics/ranking:
# OPENROUTER_SITE_URL=http://localhost:3000
# OPENROUTER_APP_NAME=ai-fluency-gym

# OpenAI (optional alternative)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4.1-mini
